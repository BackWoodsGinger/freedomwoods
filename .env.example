# Copy to .env and set values. Never commit .env.
# Required in production:
DJANGO_SECRET_KEY=your-long-random-secret-key-at-least-50-chars
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=home.freedomwoods.online
DJANGO_CSRF_TRUSTED_ORIGINS=https://home.freedomwoods.online

# Optional: set to 0 if SSL is terminated elsewhere and you don't want Django to redirect HTTP->HTTPS
# DJANGO_SECURE_SSL_REDIRECT=1
